#simple calculator
num1 = float(input("Enter first number: "))
num2 = float(input("Enter second number: "))    
operation = input("Enter operation (+, -, *, /): ")     
if operation == '+':
    result = num1 + num2    
elif operation == '-':
    result = num1 - num2    
elif operation == '*':
    result = num1 * num2
elif operation == '/':
    if num2 != 0:                        #it will be undefined and gives an error
        result = num1 / num2
    else:
        result = "Error: Division by zero"
print("Result:", result)
